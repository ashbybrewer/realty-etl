# .env.example — copy to .env and fill in your values
# All variables are prefixed with REALTY_

# ── API ──────────────────────────────────────────────────────────
REALTY_API_BASE_URL=https://api.mocklistings.io/v2
REALTY_API_KEY=your_api_key_here
REALTY_API_TIMEOUT_SECONDS=30
REALTY_API_MAX_RETRIES=5
REALTY_API_RETRY_BACKOFF_FACTOR=1.5
REALTY_API_RATE_LIMIT_PER_MINUTE=60
REALTY_API_PAGE_SIZE=100

# ── Markets ───────────────────────────────────────────────────────
REALTY_TARGET_MARKETS=["Nashville, TN","Hopkinsville, KY","Clarksville, TN"]

# ── ETL ───────────────────────────────────────────────────────────
REALTY_RAW_DUMP_ENABLED=true
REALTY_DEDUP_WINDOW_DAYS=7
REALTY_LOG_LEVEL=INFO

# ── Financial assumptions ─────────────────────────────────────────
REALTY_DEFAULT_VACANCY_RATE=0.08
REALTY_DEFAULT_EXPENSE_RATIO=0.40
REALTY_TARGET_CAP_RATE_MIN=0.06
REALTY_CLOSING_COST_PCT=0.03
REALTY_ANNUAL_APPRECIATION_ASSUMPTION=0.03

# ── DuckDB ───────────────────────────────────────────────────────
REALTY_DB_THREADS=4
REALTY_DB_MEMORY_LIMIT=2GB
